<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.programmer.escrow.community.mapper.CommunityReplyMapper">

    <resultMap id="CommunityReplyResultMap" type="com.programmer.escrow.community.entity.CommunityReplyEntity">
        <id column="id" property="id"/>
        <result column="post_id" property="postId"/>
        <result column="creator_id" property="creatorId"/>
        <result column="parent_reply_id" property="parentReplyId"/>
        <result column="author_name" property="authorName"/>
        <result column="reply_to_author_name" property="replyToAuthorName"/>
        <result column="content" property="content"/>
        <result column="like_count" property="likeCount"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, post_id, creator_id, parent_reply_id, author_name, reply_to_author_name, content, like_count, status, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.programmer.escrow.community.entity.CommunityReplyEntity" useGeneratedKeys="true" keyProperty="id">
        insert into `community_reply` (
            post_id, creator_id, parent_reply_id, author_name, reply_to_author_name, content, like_count, status, created_at, updated_at
        ) values (
            #{postId}, #{creatorId}, #{parentReplyId}, #{authorName}, #{replyToAuthorName}, #{content}, #{likeCount}, #{status}, #{createdAt}, #{updatedAt}
        )
    </insert>

    <select id="selectById" resultMap="CommunityReplyResultMap">
        select <include refid="BaseColumns"/>
        from `community_reply`
        where id = #{id}
        limit 1
    </select>

    <select id="selectList" resultMap="CommunityReplyResultMap">
        select <include refid="BaseColumns"/>
        from `community_reply`
        <where>
            <if test="postId != null">
                post_id = #{postId}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by created_at asc, id asc
    </select>

    <select id="countActiveByPostId" resultType="int">
        select count(1)
        from `community_reply`
        where post_id = #{postId}
          and status = 1
    </select>

    <update id="updateStatus">
        update `community_reply`
        set status = #{status},
            updated_at = now()
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from `community_reply`
        where id = #{id}
    </delete>

    <delete id="deleteByPostId">
        delete from `community_reply`
        where post_id = #{postId}
    </delete>
</mapper>
